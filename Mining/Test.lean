def letters := ["a", "b", "c", "d", "e", "f", "g", "h"]

def letterIds (level : Nat) (baseLevel : Nat := 0) : List Identity :=
  (letterValues[level]!.zip (letters)).map (fun pair =>
    (⟨baseLevel + level, pair.2⟩, pair.1))

def allLetterIdentities : List (List Identity) :=
  letterValues.mapFinIdx (fun index _ _ => letterIds index 99 )

