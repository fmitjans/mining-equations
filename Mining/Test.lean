#eval inputIdentities.length

def wTest :=
  System.empty
  |> (·.addList Sha256.wEquations)
  |> (·.addList inputIdentities)

#eval wTest
def results := { (wTest.goFoward 1) with answers := {}}.goFoward 100 #eval results
#eval wIdentities.map (fun wid =>
  s!"result: {results.answers[wid.1]?}, correct: {wid}, veredict: {results.answers[wid.1]?.elim false (fun r => r == wid.2)}")

def basicSystem := System.basicSha
  |> (·.addList (inputIdentities.take 15))
  -- |> (·.addList (Sha256.miningIdentities 100))

def withoutMining := basicSystem.goFoward 500
def withMining :=
  { withoutMining with answers := {} }
  |> (·.addList (Sha256.miningIdentities 100))
  |> (·.goFoward 200)

#eval withoutMining
#eval withMining
